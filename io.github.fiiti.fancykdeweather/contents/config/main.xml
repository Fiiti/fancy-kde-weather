<?xml version="1.0" encoding="UTF-8"?>
<kcfg xmlns="http://www.kde.org/standards/kcfg/1.0"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.kde.org/standards/kcfg/1.0
      http://www.kde.org/standards/kcfg/1.0/kcfg.xsd">
    <kcfgfile name=""/>

    <group name="General">
        <!-- Verbindung -->
        <entry name="apiKey" type="String">
            <default></default>
            <label>Weather.com API Key</label>
        </entry>
        <entry name="latitude" type="Double">
            <default>71.169951</default>
            <label>Latitude</label>
        </entry>
        <entry name="longitude" type="Double">
            <default>25.785889</default>
            <label>Longitude</label>
        </entry>
        <entry name="language" type="String">
            <default>de-DE</default>
            <label>Sprache (z.B. de-DE, en-US)</label>
        </entry>
        <entry name="units" type="String">
            <default>m</default>
            <label>Einheiten: m=metrisch, e=imperial, h=hybrid</label>
        </entry>
        <entry name="updateInterval" type="Int">
            <default>600</default>
            <label>Update interval in seconds (UI shows minutes)</label>
        </entry>

        <!-- Darstellung: Anzeige -->
        <entry name="showClock" type="Bool">
            <default>true</default>
            <label>Uhrzeit anzeigen</label>
        </entry>

        <!-- Darstellung: Hintergrund -->
        <entry name="bgColor" type="String">
            <default>#0D1220</default>
            <label>Hintergrundfarbe (Hex #rrggbb)</label>
        </entry>
        <entry name="bgAlpha" type="Double">
            <default>0.92</default>
            <label>Hintergrund-Deckkraft (0.0=transparent … 1.0=opak)</label>
        </entry>

        <!-- Gespeicherte Widget-Größe (Pixel) — 0 = noch nicht gesetzt -->
        <entry name="savedWidth" type="Int">
            <default>0</default>
            <label>Saved widget width in pixels</label>
        </entry>
        <entry name="savedHeight" type="Int">
            <default>0</default>
            <label>Saved widget height in pixels</label>
        </entry>

    </group>

</kcfg>
