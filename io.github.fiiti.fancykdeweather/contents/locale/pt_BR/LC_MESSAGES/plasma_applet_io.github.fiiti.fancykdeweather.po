# ConfigConnection.qml
msgid "API Key:"
msgstr "Chave API:"

msgid "Enter Visual Crossing API key"
msgstr "Insira a chave API do Visual Crossing"

msgid "Latitude:"
msgstr "Latitude:"

msgid "Longitude:"
msgstr "Longitude:"

msgid "Find coordinates:"
msgstr "Encontrar coordenadas:"

msgid "Language:"
msgstr "Idioma:"

msgid "Units:"
msgstr "Unidades:"

msgid "Metric (°C, km/h, hPa, km)"
msgstr "Métrico (°C, km/h, hPa, km)"

msgid "Imperial (°F, mph, inHg, mi)"
msgstr "Imperial (°F, mph, inHg, mi)"

msgid "Hybrid (°C, mph, hPa, km)"
msgstr "Híbrido (°C, mph, hPa, km)"

msgid "Display:"
msgstr "Exibição:"

