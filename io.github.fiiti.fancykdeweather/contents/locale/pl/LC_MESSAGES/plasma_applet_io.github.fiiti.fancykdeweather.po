msgid "Please enter your API key in the settings."
msgstr "Wprowadź klucz API w ustawieniach."

msgid "Loading weather data…"
msgstr "Ładowanie danych pogodowych…"

# ConfigConnection.qml
msgid "API Key:"
msgstr "Klucz API:"

msgid "Enter Visual Crossing API key"
msgstr "Wprowadź klucz API Visual Crossing"

msgid "Latitude:"
msgstr "Szerokość geograficzna:"

msgid "Longitude:"
msgstr "Długość geograficzna:"

msgid "Find coordinates:"
msgstr "Znajdź współrzędne:"

msgid "Language:"
msgstr "Język:"

msgid "Units:"
msgstr "Jednostki:"

msgid "Metric (°C, km/h, hPa, km)"
msgstr "Metryczny (°C, km/h, hPa, km)"

msgid "Imperial (°F, mph, inHg, mi)"
msgstr "Imperialny (°F, mph, inHg, mi)"

msgid "Hybrid (°C, mph, hPa, km)"
msgstr "Hybrydowy (°C, mph, hPa, km)"

msgid "Display:"
msgstr "Wyświetlanie:"

msgid "Show clock"
msgstr "Pokaż zegar"

msgid "Update interval (minutes):"
msgstr "Interwał aktualizacji (minuty):"

msgid "Free key at"
msgstr "Darmowy klucz na"

# ConfigAppearance.qml
msgid "Preview:"
msgstr "Podgląd:"

msgid "Background"
msgstr "Tło"

msgid "Color:"
msgstr "Kolor:"

msgid "Opacity:"
msgstr "Przezroczystość:"

# main.qml — error messages
msgid "Unable to reach weather service."
msgstr "Nie można połączyć się z serwisem pogodowym."

msgid "Invalid request — check your coordinates."
msgstr "Nieprawidłowe żądanie — sprawdź współrzędne."

msgid "Invalid API key — please check your settings."
msgstr "Nieprawidłowy klucz API — sprawdź ustawienia."

msgid "API rate limit reached."
msgstr "Osiągnięto limit API."

msgid "Weather service error (%1)."
msgstr "Błąd serwisu pogodowego (%1)."

msgid "Could not parse weather data."
msgstr "Nie udało się przetworzyć danych pogodowych."

msgid "Unknown error."
msgstr "Nieznany błąd."

# FullRepresentation.qml — retry countdown
msgid "Retrying in %1 s…"
msgstr "Ponawiam próbę za %1 s…"

# ConfigConnection.qml — update interval hint
msgid "Tip: Updating every 60 minutes is sufficient — weather changes slowly."
msgstr "Wskazówka: Aktualizacja co 60 minut jest wystarczająca — pogoda zmienia się powoli."
