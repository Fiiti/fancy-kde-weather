# config/config.qml
msgid "General"
msgstr "Ogólne"

msgid "Appearance"
msgstr "Wygląd"

# CurrentWeather.qml
msgid "Feels like %1%2"
msgstr "Odczuwalna %1%2"

msgid "Humidity"
msgstr "Wilgotność"

msgid "Pressure"
msgstr "Ciśnienie"

msgid "Wind"
msgstr "Wiatr"

msgid "Gusts"
msgstr "Porywy"

msgid "Visibility"
msgstr "Widoczność"

msgid "UV Index"
msgstr "Indeks UV"

msgid "Dew point"
msgstr "Punkt rosy"

# DailyForecast.qml
msgid "Today"
msgstr "Dziś"

