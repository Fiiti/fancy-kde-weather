# config/config.qml
msgid "General"
msgstr "常规"

msgid "Appearance"
msgstr "外观"

# CurrentWeather.qml
msgid "Feels like %1%2"
msgstr "体感 %1%2"

msgid "Humidity"
msgstr "湿度"

msgid "Pressure"
msgstr "气压"

msgid "Wind"
msgstr "风"

msgid "Gusts"
msgstr "阵风"

msgid "Visibility"
msgstr "能见度"

msgid "UV Index"
msgstr "紫外线指数"

msgid "Dew point"
msgstr "露点"

# DailyForecast.qml
msgid "Today"
msgstr "今天"

# main.qml / FullRepresentation.qml
msgid "Please enter your API key in the settings."
msgstr "请在设置中输入您的 API 密钥。"

msgid "Loading weather data…"
msgstr "正在加载天气数据…"

# ConfigConnection.qml
msgid "API Key:"
msgstr "API 密钥："

msgid "Enter Visual Crossing API key"
msgstr "输入 Visual Crossing API 密钥"

msgid "Latitude:"
msgstr "纬度："

msgid "Longitude:"
msgstr "经度："

msgid "Find coordinates:"
msgstr "查找坐标："

msgid "Language:"
msgstr "语言："

msgid "Units:"
msgstr "单位："

msgid "Metric (°C, km/h, hPa, km)"
msgstr "公制 (°C, km/h, hPa, km)"

msgid "Imperial (°F, mph, inHg, mi)"
msgstr "英制 (°F, mph, inHg, mi)"

msgid "Hybrid (°C, mph, hPa, km)"
msgstr "混合 (°C, mph, hPa, km)"

msgid "Display:"
msgstr "显示："

msgid "Show clock"
msgstr "显示时钟"

msgid "Update interval (minutes):"
msgstr "更新间隔（分钟）："

msgid "Free key at"
msgstr "免费密钥获取于"

# ConfigAppearance.qml
msgid "Preview:"
msgstr "预览："

msgid "Background"
msgstr "背景"

msgid "Color:"
msgstr "颜色："

msgid "Opacity:"
msgstr "不透明度："

# main.qml — error messages
msgid "Unable to reach weather service."
msgstr "无法连接到天气服务。"

msgid "Invalid request — check your coordinates."
msgstr "请求无效，请检查坐标。"

msgid "Invalid API key — please check your settings."
msgstr "API 密钥无效，请检查设置。"

msgid "API rate limit reached."
msgstr "已达到 API 请求限制。"

msgid "Weather service error (%1)."
msgstr "天气服务错误（%1）。"

msgid "Could not parse weather data."
msgstr "无法解析天气数据。"

msgid "Unknown error."
msgstr "未知错误。"

# FullRepresentation.qml — retry countdown
msgid "Retrying in %1 s…"
msgstr "%1 秒后重试…"

# ConfigConnection.qml — update interval hint
msgid "Tip: Updating every 60 minutes is sufficient — weather changes slowly."
msgstr "提示：每 60 分钟更新一次即可，天气变化缓慢。"


