# config/config.qml
msgid "General"
msgstr "Général"

msgid "Appearance"
msgstr "Apparence"

# CurrentWeather.qml
msgid "Feels like %1%2"
msgstr "Ressenti %1%2"

msgid "Humidity"
msgstr "Humidité"

msgid "Pressure"
msgstr "Pression"

msgid "Wind"
msgstr "Vent"

msgid "Gusts"
msgstr "Rafales"

msgid "Visibility"
msgstr "Visibilité"

msgid "UV Index"
msgstr "Indice UV"

msgid "Dew point"
msgstr "Point de rosée"

# DailyForecast.qml
msgid "Today"
msgstr "Aujourd'hui"

# main.qml / FullRepresentation.qml
msgid "Please enter your API key in the settings."
msgstr "Veuillez entrer votre clé API dans les paramètres."

msgid "Loading weather data…"
msgstr "Chargement des données météo…"

# ConfigConnection.qml
msgid "API Key:"
msgstr "Clé API :"

msgid "Enter Visual Crossing API key"
msgstr "Entrez la clé API Visual Crossing"

msgid "Latitude:"
msgstr "Latitude :"

msgid "Longitude:"
msgstr "Longitude :"

msgid "Find coordinates:"
msgstr "Trouver les coordonnées :"

msgid "Language:"
msgstr "Langue :"

msgid "Units:"
msgstr "Unités :"

msgid "Metric (°C, km/h, hPa, km)"
msgstr "Métrique (°C, km/h, hPa, km)"

msgid "Imperial (°F, mph, inHg, mi)"
msgstr "Impérial (°F, mph, inHg, mi)"

msgid "Hybrid (°C, mph, hPa, km)"
msgstr "Hybride (°C, mph, hPa, km)"

msgid "Display:"
msgstr "Affichage :"

msgid "Show clock"
msgstr "Afficher l'horloge"

msgid "Update interval (minutes):"
msgstr "Intervalle de mise à jour (minutes) :"

msgid "Free key at"
msgstr "Clé gratuite sur"

# ConfigAppearance.qml
msgid "Preview:"
msgstr "Aperçu :"

msgid "Background"
msgstr "Arrière-plan"

msgid "Color:"
msgstr "Couleur :"

msgid "Opacity:"
msgstr "Opacité :"

# main.qml — error messages
msgid "Unable to reach weather service."
msgstr "Impossible d'atteindre le service météo."

msgid "Invalid request — check your coordinates."
msgstr "Requête invalide — vérifiez vos coordonnées."

msgid "Invalid API key — please check your settings."
msgstr "Clé API invalide — vérifiez vos paramètres."

msgid "API rate limit reached."
msgstr "Limite d'API atteinte."

msgid "Weather service error (%1)."
msgstr "Erreur du service météo (%1)."

msgid "Could not parse weather data."
msgstr "Impossible d'analyser les données météo."

msgid "Unknown error."
msgstr "Erreur inconnue."

# FullRepresentation.qml — retry countdown
msgid "Retrying in %1 s…"
msgstr "Nouvelle tentative dans %1 s…"

# ConfigConnection.qml — update interval hint
msgid "Tip: Updating every 60 minutes is sufficient — weather changes slowly."
msgstr "Astuce : Une mise à jour toutes les 60 minutes est suffisante — la météo évolue lentement."


