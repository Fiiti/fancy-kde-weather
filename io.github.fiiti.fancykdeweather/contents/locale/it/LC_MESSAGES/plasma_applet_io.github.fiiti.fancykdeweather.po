msgid "Please enter your API key in the settings."
msgstr "Inserisci la tua chiave API nelle impostazioni."

msgid "Loading weather data…"
msgstr "Caricamento dati meteo…"

# ConfigConnection.qml
msgid "API Key:"
msgstr "Chiave API:"

msgid "Enter Visual Crossing API key"
msgstr "Inserisci la chiave API Visual Crossing"

msgid "Latitude:"
msgstr "Latitudine:"

msgid "Longitude:"
msgstr "Longitudine:"

msgid "Find coordinates:"
msgstr "Trova coordinate:"

msgid "Language:"
msgstr "Lingua:"

msgid "Units:"
msgstr "Unità:"

msgid "Metric (°C, km/h, hPa, km)"
msgstr "Metrico (°C, km/h, hPa, km)"

msgid "Imperial (°F, mph, inHg, mi)"
msgstr "Imperiale (°F, mph, inHg, mi)"

msgid "Hybrid (°C, mph, hPa, km)"
msgstr "Ibrido (°C, mph, hPa, km)"

msgid "Display:"
msgstr "Visualizzazione:"

msgid "Show clock"
msgstr "Mostra orologio"

msgid "Update interval (minutes):"
msgstr "Intervallo di aggiornamento (minuti):"

msgid "Free key at"
msgstr "Chiave gratuita su"

