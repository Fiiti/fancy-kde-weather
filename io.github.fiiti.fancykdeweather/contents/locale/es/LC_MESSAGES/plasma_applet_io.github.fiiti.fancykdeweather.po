msgid "Feels like %1%2"
msgstr "Sensación %1%2"

msgid "Humidity"
msgstr "Humedad"

msgid "Pressure"
msgstr "Presión"

msgid "Wind"
msgstr "Viento"

msgid "Gusts"
msgstr "Ráfagas"

msgid "Visibility"
msgstr "Visibilidad"

