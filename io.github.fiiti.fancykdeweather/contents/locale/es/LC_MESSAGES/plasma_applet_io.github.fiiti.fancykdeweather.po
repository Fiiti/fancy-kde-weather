msgid "Please enter your API key in the settings."
msgstr "Por favor, introduce tu clave API en la configuración."

msgid "Loading weather data…"
msgstr "Cargando datos meteorológicos…"

# ConfigConnection.qml
msgid "API Key:"
msgstr "Clave API:"

msgid "Enter Visual Crossing API key"
msgstr "Introduce la clave API de Visual Crossing"

msgid "Latitude:"
msgstr "Latitud:"

msgid "Longitude:"
msgstr "Longitud:"

msgid "Find coordinates:"
msgstr "Buscar coordenadas:"

msgid "Language:"
msgstr "Idioma:"

msgid "Units:"
msgstr "Unidades:"

msgid "Metric (°C, km/h, hPa, km)"
msgstr "Métrico (°C, km/h, hPa, km)"

msgid "Imperial (°F, mph, inHg, mi)"
msgstr "Imperial (°F, mph, inHg, mi)"

msgid "Hybrid (°C, mph, hPa, km)"
msgstr "Híbrido (°C, mph, hPa, km)"

msgid "Display:"
msgstr "Pantalla:"

msgid "Show clock"
msgstr "Mostrar reloj"

msgid "Update interval (minutes):"
msgstr "Intervalo de actualización (minutos):"

